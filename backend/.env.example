# Server Configuration
PORT=5000

# Database Configuration
# Get your URI from MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/task-manager?retryWrites=true&w=majority

# Security
# In production, set this to your frontend URL (e.g., https://your-app.vercel.app)
CORS_ORIGIN=*
